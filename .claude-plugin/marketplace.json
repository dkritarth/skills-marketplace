  "plugins": [
    {
      "name": "writing",
      "description": "Paper-writing skill that tracks a draft's modification history across sessions via a per-draft journal file backed by git, and infers the draft's forward trajectory (not just past diffs). The flagship skill in this marketplace.",
      "source": "./skills/writing",
      "category": "writing"
    },
    {
      "name": "latex",
      "description": "Narrow-scoped LaTeX skill: venue templates, compile-error log triage (points at the actual offending file/line), and bib hygiene (duplicate keys, missing fields).",
      "source": "./skills/latex",
      "category": "writing"
    },
    {
      "name": "math",
      "description": "Proof structure enforcement (claim/assumptions/proof/where-used) plus a real SymPy verification round-trip for symbolic and numeric sub-claims, with Lean-formalization candidates flagged (not forced).",
